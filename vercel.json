{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/server.js" },
    { "source": "/(.*)", "destination": "/ngl.js" },
    { "source": "/(.*)", "destination": "/style.css" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
